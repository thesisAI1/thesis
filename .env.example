# ─────────────────────────────────────────────────────────────
# THESIS — environment configuration
#
# Copy this file to `.env` and fill in keys WHEN you are ready to go live.
# With no keys and THESIS_MODE=mock, the whole system runs locally for $0.
# Load it by running the backend with:  node --env-file=.env ...
# ─────────────────────────────────────────────────────────────

# mock = no external calls, fake data, costs $0  (default)
# live = real APIs (requires the keys below)
THESIS_MODE=mock

# --- Frontrun API — X intelligence: CA history, smart followers ---
# Paid plan ~$200/mo · https://docs.frontrun.pro/paid-api-plan
FRONTRUN_API_KEY=
FRONTRUN_API_BASE=https://api.frontrun.pro

# --- X / Twitter API — mention monitoring + author timelines ---
X_BEARER_TOKEN=
# Numeric id of the agent's own X account (the account whose mentions we poll).
X_AGENT_USER_ID=
# OAuth 1.0a credentials — required for the agent to POST replies (buy /
# exit announcements and author payout requests). Generate these for the
# agent's own X account in the X developer portal.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# --- Base chain token data — free tiers available ---
BASEDATA_PROVIDER=dexscreener
BIRDEYE_API_KEY=

# --- Base chain RPC ---
# Sepolia testnet for development (free); mainnet for go-live.
BASE_RPC_URL=https://sepolia.base.org
BASE_CHAIN_ID=84532

# --- Trading wallet ---
# NEVER commit a real key. Use a throwaway testnet key during development.
TRADING_WALLET_PRIVATE_KEY=
# Safety gate. Real on-chain buys/sells fire ONLY when this is exactly "true".
# Leave blank until swaps have been validated on Base Sepolia.
LIVE_TRADING_ARMED=
# Swap routing (Base mainnet defaults).
BASE_WETH=0x4200000000000000000000000000000000000006
BASE_SWAP_ROUTER=0x2626664c2603336E57B271c5C0b26F421741e481
BASE_SWAP_FEE_TIER=10000
SWAP_SLIPPAGE_PCT=8

# --- Treasury (the Endowment's 25/25/25/25 split) ---
# The launched $THESIS token — needed for buyback & burn. Blank until launch.
THESIS_TOKEN_ADDRESS=
# Team / maintenance wallet — receives 25% of each winning trade.
TEAM_WALLET=
# Where bought-back $THESIS is sent to be burned.
BURN_ADDRESS=0x000000000000000000000000000000000000dEaD

# --- 0x Swap API (DEX aggregator) ---
# Routes swaps through Uniswap v2/v3/v4, Aerodrome and 150+ DEXes automatically.
# Free key at https://dashboard.0x.org/. Required for live swaps.
ZEROEX_API_KEY=

# --- LLM — the Dean agent ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- HTTP server / website ---
PORT=4319
PUBLIC_BASE_URL=http://localhost:4319

# --- Database ---
DATABASE_URL=postgres://localhost:5432/thesis
DATA_DIR=./data

# --- Service loops ---
POLL_INTERVAL_SEC=300
REVIEW_INTERVAL_SEC=20
MONITOR_INTERVAL_SEC=15

# --- Auditor (token gates) ---
MIN_TOKEN_AGE_HOURS=1
MAX_TOP10_PCT=30
# Market cap band (USD). Below the floor = too micro-cap / rug-prone;
# above the ceiling = already "discovered", limited upside.
MIN_MARKET_CAP_USD=40000
MAX_MARKET_CAP_USD=3000000
# BaseScan/Etherscan API key — for the Clanker launchpad deployer check (free tier).
BASESCAN_API_KEY=

# --- Triage (mention selection) ---
MIN_AUTHOR_FOLLOWERS=50
MIN_THESIS_WORDS=6
AUTHOR_COOLDOWN_HOURS=3
CONTRACT_DEDUP_HOURS=6
REVIEW_BUDGET_PER_HOUR=30
QUEUE_TTL_MIN=40

# --- Trading parameters ---
# The take-profit ladder (TP1 50%@+100%, TP2 25%@+200%, TP3 15%@+300%,
# TP4 10%@+1000%) is in code: config.trading.takeProfitTiers. The stop-loss
# trails 30% below the highest tier the position has reached.
POSITION_SIZE_MIN_PCT=5
POSITION_SIZE_MAX_PCT=10
STOP_LOSS_PCT=30
MAX_BUYS_PER_DAY=15
BUY_COOLDOWN_MINUTES=30
